{
  "name": "ingestion-module",
  "version": "1.0.0",
  "engines": { "node": ">=18" },
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "transform": {
      "^.+\\.ts$": ["ts-jest", {
        "tsconfig": {
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true,
          "target": "ES2022",
          "module": "CommonJS"
        }
      }]
    }
  }
}
