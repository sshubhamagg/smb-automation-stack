  "dependencies": {
    "axios": "^1.13.6",
    "node-fetch": "^3.3.2",
    "shared-types": "file:../shared"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  }
}
