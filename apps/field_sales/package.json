{
  "name": "field-sales",
  "version": "1.0.0",
  "engines": { "node": ">=18" },
  "scripts": {
    "dev": "ts-node src/server.ts",
    "start": "ts-node src/server.ts",
    "test": "jest"
  },
  "dependencies": {
    "communication-module": "file:../../modules/communication",
    "dotenv": "^16.0.0",
    "engine-module": "file:../../modules/engine",
    "express": "^4.18.0",
    "ingestion-module": "file:../../modules/ingestion",
    "intelligence-module": "file:../../modules/intelligence",
    "node-cron": "^4.2.1",
    "storage-module": "file:../../modules/storage"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "transform": {
      "^.+\\.ts$": ["ts-jest", {
        "tsconfig": {
          "rootDir": ".",
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true,
          "target": "ES2022",
          "module": "CommonJS"
        }
      }]
    }
  }
}
