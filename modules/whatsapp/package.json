{
  "name": "whatsapp-module",
  "version": "1.0.0",
  "engines": { "node": ">=18" },
  "scripts": {
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "test": "jest"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "fastify-raw-body": "^4.3.0",
    "redis": "^4.7.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "@types/better-sqlite3": "^7.6.0",
    "tsx": "^4.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "transform": {
      "^.+\\.ts$": ["ts-jest", {
        "tsconfig": {
          "rootDir": ".",
          "strict": true,
          "esModuleInterop": true,
          "skipLibCheck": true,
          "target": "ES2022",
          "module": "CommonJS"
        }
      }]
    }
  }
}
